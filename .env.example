NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx

# Server-only. Never prefix with NEXT_PUBLIC.
# Used to load /portal/[token] and submit guest check-ins without exposing
# reservations or documents through the public browser client.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx

# Optional legacy fallback if your project still uses legacy keys.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
