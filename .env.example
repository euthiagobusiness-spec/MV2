NEXT_PUBLIC_SITE_URL=https://localhost:5004
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxx

# Server-only. Never prefix with NEXT_PUBLIC.
# Used to load /portal/[token] and submit guest check-ins without exposing
# reservations or documents through the public browser client.
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxx

# Development-only fallback when Supabase is not configured.
# Never use weak or shared passwords in production.
ADMIN_DEMO_EMAIL=admin@mv2temporada.com.br
ADMIN_DEMO_PASSWORD=MV2-demo-2026!

# Production admin access allowlist. Keep it server-only.
ADMIN_ALLOWED_EMAILS=admin@mv2temporada.com.br

# Operational verification email notifications.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=usuario@example.com
SMTP_PASS=senha-segura
EMAIL_FROM=operacao@mv2temporada.com.br
EMAIL_TO=admin@mv2temporada.com.br

# Optional legacy fallback if your project still uses legacy keys.
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
